{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state.schema.json",
  "type": "object",
  "required": ["shot_id"],
  "properties": {
    "shot_id": { "type": "string", "description": "The shot that produced this state" },
    "characters": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "properties": {
            "outfit": { "type": "string" },
            "pose": { "type": "string" },
            "location": { "type": "string" },
            "holding": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      }
    },
    "props": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "properties": {
            "location": { "type": "string" },
            "state": { "type": "string" }
          },
          "additionalProperties": true
        }
      }
    },
    "scene": {
      "type": "object",
      "properties": {
        "lighting": { "type": "string" },
        "weather": { "type": "string" },
        "time": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
