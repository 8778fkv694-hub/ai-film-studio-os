{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shot.schema.json",
  "type": "object",
  "required": ["shot_id", "duration_s", "scene_ref"],
  "properties": {
    "shot_id": {"type": "string"},
    "duration_s": {"type": "number", "minimum": 1, "maximum": 20},
    "style_ref": {"type": "string"},
    "scene_ref": {"type": "string"},
    "cam_setup_ref": {"type": "string"},
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref"],
        "properties": {
          "ref": {"type": "string"},
          "overrides": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "props": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref"],
        "properties": {
          "ref": {"type": "string"},
          "state": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "action": {
      "type": "object",
      "properties": {
        "beats": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "dialogue": {
      "type": "object",
      "properties": {
        "speaker": {"type": "string", "description": "Character ID or name"},
        "text": {"type": "string", "description": "The line to be spoken"},
        "voice_id": {"type": "string", "description": "Optional specific voice ID"}
      },
      "required": ["speaker", "text"],
      "additionalProperties": true
    },
    "voiceover": {
      "type": "object",
      "properties": {
        "speaker": {"type": "string", "description": "Narrator or commentator name"},
        "text": {"type": "string", "description": "Narration/explanation for this shot"},
        "voice_id": {"type": "string", "description": "Optional specific voice ID"}
      },
      "required": ["text"],
      "additionalProperties": true
    },
    "continuity": {
      "type": "object",
      "properties": {
        "state_in_ref": {
          "type": "string",
          "description": "Path to the state JSON file from the previous shot (e.g. states/S000.json)"
        },
        "state_changes": {
          "type": "object",
          "description": "Changes to the state that occur during this shot",
          "properties": {
            "characters": { "type": "object" },
            "props": { "type": "object" },
            "scene": { "type": "object" }
          }
        },
        "must_match_prev": { "type": "array", "items": { "type": "string" } },
        "handoff_to_next": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "budget": {
      "type": "object",
      "properties": {
        "tier": {"type": "string", "enum": ["cheap", "standard", "final"]},
        "max_regen": {"type": "integer", "minimum": 0, "maximum": 20}
      },
      "additionalProperties": true
    },
    "context_refs": {
      "type": "array",
      "description": "Paths to previous shot keyframes used as visual conditioning context. Empty or absent for the first shot in a sequence.",
      "items": { "type": "string" }
    },
    "prompt": {
      "type": "object",
      "properties": {
        "positive": {"type": "string"},
        "negative": {"type": "string"},
        "references": {"type": "object"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
