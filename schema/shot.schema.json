{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shot.schema.json",
  "type": "object",
  "required": ["shot_id", "duration_s", "scene_ref"],
  "properties": {
    "shot_id": {"type": "string"},
    "duration_s": {"type": "number", "minimum": 1, "maximum": 60},
    "style_ref": {"type": "string"},
    "scene_ref": {"type": "string"},
    "cam_setup_ref": {"type": "string"},
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref"],
        "properties": {
          "ref": {"type": "string"},
          "overrides": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "props": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref"],
        "properties": {
          "ref": {"type": "string"},
          "state": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "action": {
      "type": "object",
      "properties": {
        "beats": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "dialogue": {
      "type": ["object", "null"],
      "properties": {
        "speaker": {"type": "string", "description": "Character ID or name"},
        "text": {"type": "string", "description": "The line to be spoken"},
        "voice_id": {"type": "string", "description": "Optional specific voice ID"}
      },
      "required": ["speaker", "text"],
      "additionalProperties": true
    },
    "voiceover": {
      "type": ["object", "null"],
      "properties": {
        "speaker": {"type": "string", "description": "Narrator or commentator name"},
        "text": {"type": "string", "description": "Narration/explanation for this shot"},
        "voice_id": {"type": "string", "description": "Optional specific voice ID"}
      },
      "required": ["text"],
      "additionalProperties": true
    },
    "continuity": {
      "type": "object",
      "properties": {
        "state_in_ref": {
          "type": "string",
          "description": "Path to the state JSON file from the previous shot (e.g. states/S000.json)"
        },
        "state_changes": {
          "type": "object",
          "description": "Changes to the state that occur during this shot",
          "properties": {
            "characters": { "type": "object" },
            "props": { "type": "object" },
            "scene": { "type": "object" }
          }
        },
        "must_match_prev": { "type": "array", "items": { "type": "string" } },
        "handoff_to_next": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "budget": {
      "type": "object",
      "properties": {
        "tier": {"type": "string", "enum": ["cheap", "standard", "final"]},
        "max_regen": {"type": "integer", "minimum": 0, "maximum": 20}
      },
      "additionalProperties": true
    },
    "context_refs": {
      "type": "array",
      "description": "Paths to previous shot keyframes used as visual conditioning context. Empty or absent for the first shot in a sequence.",
      "items": { "type": "string" }
    },
    "prompt": {
      "type": "object",
      "properties": {
        "positive": {"type": "string"},
        "negative": {"type": "string"},
        "references": {"type": "object"}
      },
      "additionalProperties": true
    },
    "blocking": {
      "type": "object",
      "description": "Top-down spatial staging for this shot. All optional; absent means no spatial constraints (backward compatible). Coordinates are a 0-100 normalized top-down plane: x 0=left(west) 100=right(east), y 0=far/back(north) 100=near/front(south).",
      "properties": {
        "grid": {"type": "string", "description": "e.g. '5x5' or 'continuous'"},
        "mode": {
          "type": "string",
          "enum": ["lock", "guide", "off"],
          "description": "Spatial enforcement when compiling prompts: 'lock' = AI must follow exactly (+gray-box scaffold); 'guide' = soft suggestion the AI may adjust (default); 'off' = inject nothing, AI composes freely. Absent = guide."
        },
        "floorplan_ref": {"type": "string", "description": "Reuse the scene-level floorplan; 'scene' = use this shot's scene_ref floorplan"},
        "camera": {
          "type": "object",
          "description": "FrameForge-style camera record",
          "properties": {
            "x": {"type": "number", "minimum": 0, "maximum": 100},
            "y": {"type": "number", "minimum": 0, "maximum": 100},
            "facing": {"description": "Compass (N/NE/E/SE/S/SW/W/NW) or degrees (0=N, clockwise)"},
            "height": {"type": "string", "enum": ["low", "eye_level", "high", "overhead"]},
            "tilt": {"type": "number", "description": "Pitch in degrees; positive=looking up (low angle), negative=looking down (high angle)"},
            "roll": {"type": "number", "description": "Dutch-angle roll in degrees"},
            "lens": {"type": "string", "description": "Focal length e.g. '35mm'"},
            "shot_size": {"type": "string"},
            "dof": {"type": "string", "enum": ["shallow", "normal", "deep"]}
          },
          "additionalProperties": true
        },
        "entities": {
          "type": "array",
          "description": "Starting positions of characters/props on the top-down plane",
          "items": {
            "type": "object",
            "required": ["ref", "x", "y"],
            "properties": {
              "ref": {"type": "string", "description": "Character/prop ref path, or 'prop:<id>' / 'fixture:<id>'"},
              "x": {"type": "number", "minimum": 0, "maximum": 100},
              "y": {"type": "number", "minimum": 0, "maximum": 100},
              "facing": {"description": "Compass or degrees"},
              "gaze_target": {"type": "string", "description": "ref/id this entity looks at, or 'camera'"},
              "layer": {"type": "string", "enum": ["foreground", "midground", "background"]}
            },
            "additionalProperties": true
          }
        },
        "motion": {
          "type": "array",
          "description": "Shot Designer-style movement commands (video stage)",
          "items": {
            "type": "object",
            "required": ["who", "verb"],
            "properties": {
              "who": {"type": "string", "description": "entity ref/id or 'camera'"},
              "verb": {"type": "string", "enum": ["walk_to", "turn_to", "track", "push_in", "pull_out", "pan_to", "hold"]},
              "x": {"type": "number"},
              "y": {"type": "number"},
              "target": {"type": "string", "description": "entity ref/id or 'camera'"}
            },
            "additionalProperties": true
          }
        },
        "axis_lock": {"type": "string", "description": "Action axis (e.g. 'A-B') for 180-degree continuity checks across shots"}
      },
      "additionalProperties": true
    },
    "parent_shot_id": {
      "type": "string",
      "description": "The ID of the parent shot this segment was split from"
    },
    "segment_index": {
      "type": "integer",
      "minimum": 1,
      "description": "The 1-based index of this segment in the split sequence"
    },
    "segment_count": {
      "type": "integer",
      "minimum": 1,
      "description": "The total number of segments this parent shot was split into"
    },
    "split_reason": {
      "type": "string",
      "description": "The reason why the shot was split"
    }
  },
  "additionalProperties": true
}
