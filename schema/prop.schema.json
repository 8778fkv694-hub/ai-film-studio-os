{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prop.schema.json",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "must_keep": {"type": "boolean"},
    "references": {
      "type": "object",
      "properties": {
        "images": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
