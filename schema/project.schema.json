{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project.schema.json",
  "type": "object",
  "required": ["id", "name", "default_style_ref", "timeline"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "default_style_ref": {"type": "string"},
    "defaults": {
      "type": "object",
      "properties": {
        "language": {"type": "string", "enum": ["en", "zh", "bilingual"]},
        "fps": {"type": "integer", "minimum": 1, "maximum": 120},
        "budget": {
          "type": "object",
          "properties": {
            "cheap": {"type": "object"},
            "final": {"type": "object"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "inventory": {
      "type": "object",
      "properties": {
        "scenes": {"type": "array", "items": {"type": "string"}},
        "characters": {"type": "array", "items": {"type": "string"}},
        "props": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["shot_id", "shot_file"],
        "properties": {
          "shot_id": {"type": "string"},
          "shot_file": {"type": "string"},
          "tier": {"type": "string", "enum": ["cheap", "standard", "final"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
