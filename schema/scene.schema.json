{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene.schema.json",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "style_ref": {"type": "string"},
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "img", "use_for"],
        "properties": {
          "id": {"type": "string"},
          "img": {"type": "string"},
          "use_for": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "must_keep": {
      "type": "object",
      "properties": {
        "time": {"type": "string"},
        "lighting": {"type": "string"},
        "palette": {"type": "array", "items": {"type": "string"}},
        "set_elements": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "forbidden": {"type": "array", "items": {"type": "string"}},
    "floorplan": {
      "type": "object",
      "description": "Fixed set geometry reused by shots. Same 0-100 top-down plane as shot.blocking.",
      "properties": {
        "grid": {"type": "string"},
        "fixtures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "x", "y"],
            "properties": {
              "id": {"type": "string"},
              "x": {"type": "number", "minimum": 0, "maximum": 100},
              "y": {"type": "number", "minimum": 0, "maximum": 100},
              "label": {"type": "string"},
              "facing": {}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "cam_setups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "shot_size": {"type": "string"},
          "movement": {"type": "string"},
          "lens": {"type": "string"},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
