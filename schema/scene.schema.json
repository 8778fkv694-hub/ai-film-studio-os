{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene.schema.json",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "style_ref": {"type": "string"},
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "img", "use_for"],
        "properties": {
          "id": {"type": "string"},
          "img": {"type": "string"},
          "use_for": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "must_keep": {
      "type": "object",
      "properties": {
        "time": {"type": "string"},
        "lighting": {"type": "string"},
        "palette": {"type": "array", "items": {"type": "string"}},
        "set_elements": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "forbidden": {"type": "array", "items": {"type": "string"}},
    "cam_setups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "shot_size": {"type": "string"},
          "movement": {"type": "string"},
          "lens": {"type": "string"},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
