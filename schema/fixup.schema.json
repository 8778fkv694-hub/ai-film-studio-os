{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fixup.schema.json",
  "type": "object",
  "required": ["fixup_id", "target_shot_id", "target_take_id", "type", "instruction"],
  "properties": {
    "fixup_id": { "type": "string" },
    "target_shot_id": { "type": "string" },
    "target_take_id": { "type": "string" },
    "type": { "type": "string", "enum": ["inpaint", "upscale", "face_restore", "retime"] },
    "instruction": { "type": "string", "description": "Natural language instruction for the fix (e.g. 'remove the extra finger', 'brighten face')" },
    "mask_ref": { "type": "string", "description": "Path to mask image if manual masking is used" },
    "params": {
      "type": "object",
      "properties": {
        "denoise_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "scale_factor": { "type": "number" }
      }
    },
    "status": { "type": "string", "enum": ["open", "processing", "completed", "rejected"], "default": "open" },
    "result_ref": { "type": "string", "description": "Path to the fixed asset" }
  },
  "additionalProperties": true
}
